# Helius RPC
HELIUS_API_KEY=your_helius_api_key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key

# CommonStack AI API (OpenAI-compatible, supports DeepSeek/GPT/Claude/Grok)
# Get key from: https://commonstack.ai
COMMONSTACK_API_KEY=your_commonstack_api_key
# Model (default: deepseek/deepseek-chat)
# COMMONSTACK_MODEL=deepseek/deepseek-chat

# Solana wallet for live trading
# SOLANA_PRIVATE_KEY=your_base58_encoded_private_key

# X API (optional, for social posting)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
