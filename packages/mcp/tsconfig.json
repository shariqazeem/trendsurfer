{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "../..",
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "../skill/src/**/*.ts", "../../lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
