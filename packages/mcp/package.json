{
  "name": "trendsurfer-mcp",
  "version": "0.1.0",
  "description": "MCP server for TrendSurfer — expose trends.fun intelligence to any AI agent framework",
  "author": "TrendSurfer <https://github.com/shariqazeem/trendsurfer>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shariqazeem/trendsurfer.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/shariqazeem/trendsurfer#readme",
  "bugs": {
    "url": "https://github.com/shariqazeem/trendsurfer/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solana",
    "trends.fun",
    "trendsurfer",
    "ai-agent",
    "bonding-curve",
    "trading"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "trendsurfer-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "trendsurfer-skill": "*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=18"
  }
}
